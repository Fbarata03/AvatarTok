APP_NAME=AvatarTok
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.avatartok.com
APP_KEY=base64:CHANGE_ME_32_CHARS_SECRET_KEY_HERE

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=avatartok
DB_USER=avatartok_user
DB_PASS=strong_password_here

# Redis (cache, queues, pub/sub)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_QUEUE_DB=1
REDIS_PUBSUB_DB=2

# JWT
JWT_SECRET=CHANGE_ME_JWT_SECRET_KEY
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# AWS S3 (video/image storage)
AWS_KEY=
AWS_SECRET=
AWS_REGION=us-east-1
AWS_BUCKET_VIDEOS=avatartok-videos
AWS_BUCKET_ASSETS=avatartok-assets
AWS_CLOUDFRONT_URL=https://cdn.avatartok.com

# Stripe (payments)
STRIPE_PUBLIC_KEY=pk_live_
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_CONNECT_CLIENT_ID=ca_

# WebSocket (live streaming + chat)
WS_HOST=wss://live.avatartok.com
WS_PORT=8080
WS_SECRET=CHANGE_ME_WS_SECRET

# Media Processing (FFmpeg microservice)
FFMPEG_SERVICE_URL=http://media-processor:9000
FFMPEG_SERVICE_KEY=

# Facial Tracking Service (WebRTC/ML microservice)
FACE_TRACKING_URL=http://face-tracker:9001
FACE_TRACKING_KEY=

# AI Moderation (content safety)
MODERATION_SERVICE_URL=http://moderator:9002
MODERATION_SERVICE_KEY=
MODERATION_THRESHOLD=0.85

# Analytics
ANALYTICS_DB_HOST=127.0.0.1
ANALYTICS_DB_NAME=avatartok_analytics

# Push Notifications
FCM_SERVER_KEY=
APNS_KEY_PATH=/certs/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
